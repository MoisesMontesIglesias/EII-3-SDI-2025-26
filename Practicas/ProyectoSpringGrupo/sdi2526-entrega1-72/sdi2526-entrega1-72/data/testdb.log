/*C3*/SET SCHEMA PUBLIC
drop table if exists maintenance_blocks cascade 
drop table if exists reservations cascade 
drop table if exists spaces cascade 
drop table if exists users cascade 
create table maintenance_blocks (end_date_time timestamp(6) not null, id bigint generated by default as identity (start with 1), space_id bigint not null, start_date_time timestamp(6) not null, reason varchar(250) not null, status varchar(255) not null check ((status in ('ACTIVE','CANCELLED'))), primary key (id))
create table reservations (end_date_time timestamp(6) not null, id bigint generated by default as identity (start with 1), space_id bigint not null, start_date_time timestamp(6) not null, user_id bigint not null, reason varchar(250), status varchar(255) not null check ((status in ('ACTIVE','CANCELLED'))), primary key (id))
create table spaces (active boolean not null, capacity integer not null, id bigint generated by default as identity (start with 1), location varchar(255) not null, name varchar(255) not null, type varchar(255) not null, primary key (id))
create table users (id bigint generated by default as identity (start with 1), dni varchar(255) not null unique, last_name varchar(255) not null, name varchar(255) not null, password varchar(255) not null, role varchar(255) not null, primary key (id))
alter table maintenance_blocks add constraint FK3v1e1lpds1yoprqm4rbjqkghq foreign key (space_id) references spaces
alter table reservations add constraint FKamig3ih2d03a4kb15cuoax1rm foreign key (space_id) references spaces
alter table reservations add constraint FKb5g9io5h54iwl2inkno50ppln foreign key (user_id) references users
