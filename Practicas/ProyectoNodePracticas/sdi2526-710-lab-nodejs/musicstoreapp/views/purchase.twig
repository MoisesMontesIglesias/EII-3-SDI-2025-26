{% extends "layout.twig" %}
{% block title %} Mis Compras {% endblock %}
{% block main_container %}
	<h2>Mis compras</h2>
	<div class="table-responsive">
		<table class="table table-hover">
			<thead>
			<tr>
				<th>Nombre</th>
				<th>Genero</th>
				<th class="col-md-1"></th>
				<th>Portada</th>
			</tr>
			</thead>
			<tbody>
			{% for song in songs %}
				<tr>
					<td>{{ song.title }}</td>
					<td>{{ song.kind }}</td>
					<td>
						{% if song.previewUrl is defined and song.previewUrl != '' %}
							<audio controls>
								<source src="{{ song.previewUrl }}" type="audio/mpeg">
							</audio>
						{% else %}
							<audio controls>
								<source src="/audios/{{ song._id }}.mp3" type="audio/mpeg">
							</audio>
						{% endif %}
					</td>
					<td>
						{% if song.artworkUrl is defined and song.artworkUrl != '' %}
							<img src="{{ song.artworkUrl }}" alt="{{ song.title }}" style="width: 60px;">
						{% else %}
							<img src="/covers/{{ song._id }}.png" alt="{{ song.title }}" style="width: 60px;">
						{% endif %}
					</td>
				</tr>
			{% endfor %}
			</tbody>
		</table>
	</div>
{% endblock %}
